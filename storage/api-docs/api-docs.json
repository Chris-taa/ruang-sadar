                                        "example": 2
                                    },
                                    "full_name": {
                                        "type": "string",
                                        "example": "Budi Santoso"
                                    },
                                    "consultation_date": {
                                        "type": "string",
                                        "format": "date",
                                        "example": "2026-06-25"
                                    },
                                    "topic": {
