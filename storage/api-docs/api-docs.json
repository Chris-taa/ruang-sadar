                "summary": "Simpan jurnal baru",
                "description": "Menambahkan catatan jurnal baru dengan detail mood dan penyebabnya",
                "operationId": "9c8043e3a2a19ad4ff66313e22edea62",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "mood",
                                    "date"
                                ],
                                "properties": {
                                    "mood": {
                                        "type": "string",
                                        "example": "Senang"
                                    },
                                    "cause": {
                                        "type": "array",
                                        "items": {
                                            "type": "string"
                                        },
                                        "example": [
                                            "Tugas Selesai",
                                            "Tidur Cukup"
                                        ]
                                    },
                                    "contain": {
                                        "type": "string",
                                        "example": "Hari ini sangat produktif dan menyenangkan."
                                    },
                                    "date": {
                                        "type": "string",
                                        "format": "date-time",
                                        "example": "2026-06-22 18:30:00"
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
