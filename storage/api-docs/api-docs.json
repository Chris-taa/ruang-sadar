    "paths": {
        "/api/register": {
            "post": {
                "tags": [
                    "Auth"
                ],
                "summary": "Register akun baru",
                "operationId": "a718f172ff3ac464d723835815f8fb57",
                "responses": {
                    "201": {
                        "description": "Registrasi berhasil"
                    },
                    "422": {
                        "description": "Validasi gagal"
                    }
                }
            }
        },
        "/api/login": {
            "post": {
                "tags": [
                    "Auth"
                ],
                "summary": "Login user",
                "operationId": "44212a9096e4b09358281e9ec8a0701d",
                "responses": {
                    "200": {
                        "description": "Login berhasil"
                    },
                    "401": {
                        "description": "Email atau password salah"
                    }
                }
            }
        },
        "/api/auth/google": {
            "post": {
                "tags": [
                    "Auth"
                ],
                "summary": "Login dengan Google",
                "operationId": "f53e9b3810807365b968103a33b5c93f",
                "responses": {
                    "200": {
                        "description": "Login Google berhasil"
                    },
                    "401": {
                        "description": "Token tidak valid"
                    }
                }
            }
        },
        "/api/focus-preset": {
            "get": {
                "tags": [
                    "Focus Preset"
                ],
                "summary": "Ambil semua preset fokus milik pengguna",
                "description": "Menampilkan daftar preset waktu fokus (Pomodoro atau Timer) khusus untuk user yang sedang login.",
                "operationId": "aee714c1bcb8e1b730471e9cdb4bb294",
                "responses": {
                    "200": {
                        "description": "Berhasil mengambil data preset"
                    },
                    "401": {
                        "description": "Unauthenticated"
                    }
                },
                "security": [
                    {
                        "bearerAuth": []
                    }
                ]
            },
            "post": {
                "tags": [
                    "Focus Preset"
                ],
                "summary": "Simpan preset fokus baru",
                "description": "Menambahkan preset baru. Jika tipe 'pomodoro', maka `short_break` dan `rounds` wajib diisi.",
                "operationId": "e70ceea8125d4a6a4b991a48d77bef3d",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "name",
                                    "type",
                                    "focus_duration"
                                ],
                                "properties": {
                                    "name": {
                                        "type": "string",
                                        "example": "Belajar Android"
                                    },
                                    "type": {
                                        "type": "string",
                                        "example": "pomodoro",
                                        "enum": [
                                            "pomodoro",
                                            "timer"
                                        ]
                                    },
                                    "focus_duration": {
                                        "description": "Durasi fokus dalam menit",
                                        "type": "integer",
                                        "example": 25
                                    },
                                    "short_break": {
                                        "description": "Durasi istirahat pendek dalam menit",
                                        "type": "integer",
                                        "example": 5
                                    },
                                    "long_break": {
                                        "description": "Durasi istirahat panjang dalam menit",
                                        "type": "integer",
                                        "example": 15
                                    },
                                    "rounds": {
                                        "description": "Jumlah ronde sebelum istirahat panjang",
                                        "type": "integer",
                                        "example": 4
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "201": {
                        "description": "Preset berhasil disimpan"
                    },
                    "401": {
                        "description": "Unauthenticated"
                    },
                    "422": {
                        "description": "Data tidak valid"
                    }
                },
                "security": [
                    {
                        "bearerAuth": []
                    }
                ]
            }
        },
        "/api/focus-preset/{id}": {
            "get": {
                "tags": [
                    "Focus Preset"
                ],
                "summary": "Detail satu preset fokus",
                "description": "Menampilkan detail satu preset berdasarkan ID.",
                "operationId": "16e4fe1db9f2de5065ffb09b8da5fa2c",
                "parameters": [
                    {
                        "name": "id",
                        "in": "path",
                        "description": "ID Preset",
                        "required": true,
                        "schema": {
                            "type": "integer"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Berhasil mengambil detail preset"
                    },
                    "404": {
                        "description": "Preset tidak ditemukan"
                    }
                },
                "security": [
                    {
                        "bearerAuth": []
                    }
                ]
            },
            "put": {
                "tags": [
                    "Focus Preset"
                ],
                "summary": "Update preset fokus",
                "description": "Memperbarui data preset yang sudah ada.",
                "operationId": "42b7db8d0e233a18d4fbf0b9911d1673",
                "parameters": [
                    {
                        "name": "id",
                        "in": "path",
                        "description": "ID Preset",
                        "required": true,
                        "schema": {
                            "type": "integer"
                        }
                    }
                ],
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "properties": {
                                    "name": {
                                        "type": "string",
                                        "example": "Membaca Buku"
                                    },
                                    "type": {
                                        "type": "string",
                                        "example": "timer",
                                        "enum": [
                                            "pomodoro",
                                            "timer"
                                        ]
                                    },
                                    "focus_duration": {
                                        "type": "integer",
                                        "example": 45
                                    },
                                    "short_break": {
                                        "type": "integer",
                                        "example": null
                                    },
                                    "long_break": {
                                        "type": "integer",
                                        "example": null
                                    },
                                    "rounds": {
                                        "type": "integer",
                                        "example": null
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Preset berhasil diperbarui"
                    },
                    "404": {
                        "description": "Preset tidak ditemukan"
                    },
                    "422": {
                        "description": "Data tidak valid"
                    }
                },
                "security": [
                    {
                        "bearerAuth": []
                    }
                ]
            },
            "delete": {
                "tags": [
                    "Focus Preset"
                ],
                "summary": "Hapus preset fokus",
                "description": "Menghapus preset fokus berdasarkan ID.",
                "operationId": "550d85afe1b4a0c98628c62a8e865557",
                "parameters": [
                    {
                        "name": "id",
                        "in": "path",
                        "description": "ID Preset",
                        "required": true,
                        "schema": {
                            "type": "integer"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Preset berhasil dihapus"
                    },
                    "404": {
                        "description": "Preset tidak ditemukan"
                    }
                },
                "security": [
                    {
                        "bearerAuth": []
                    }
                ]
            }
        },
        "/api/focus-session/start": {
            "post": {
                "tags": [
                    "Focus Session"
                ],
                "summary": "Mulai sesi fokus baru",
                "description": "Memulai sesi fokus. User tidak bisa memulai sesi baru jika masih ada sesi yang berstatus 'ongoing'.",
                "operationId": "d45fa80a73411deec6a7d5a67cbd120d",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "type",
                                    "planned_duration"
                                ],
                                "properties": {
                                    "preset_id": {
                                        "description": "ID dari Focus Preset (opsional)",
                                        "type": "integer",
                                        "example": 1,
                                        "nullable": true
                                    },
                                    "type": {
                                        "type": "string",
                                        "example": "pomodoro",
                                        "enum": [
                                            "pomodoro",
                                            "timer"
                                        ]
                                    },
                                    "planned_duration": {
                                        "description": "Durasi rencana dalam menit",
                                        "type": "integer",
                                        "example": 25
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "201": {
                        "description": "Sesi fokus dimulai"
                    },
                    "409": {
                        "description": "Masih ada sesi yang berjalan"
                    },
                    "422": {
                        "description": "Data tidak valid"
                    }
                },
                "security": [
                    {
                        "bearerAuth": []
                    }
                ]
            }
        },
        "/api/focus-session/{id}/end": {
            "post": {
                "tags": [
                    "Focus Session"
                ],
                "summary": "Selesaikan atau batalkan sesi fokus",
                "description": "Mengakhiri sesi fokus yang sedang berjalan dengan mengubah statusnya menjadi completed atau cancelled.",
                "operationId": "45b4c5dbe88cf07d504af6427edc1796",
                "parameters": [
                    {
                        "name": "id",
                        "in": "path",
                        "description": "ID Sesi Fokus",
                        "required": true,
                        "schema": {
                            "type": "integer"
                        }
                    }
                ],
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "status",
                                    "actual_duration"
                                ],
                                "properties": {
                                    "status": {
                                        "type": "string",
                                        "example": "completed",
                                        "enum": [
                                            "completed",
                                            "cancelled"
                                        ]
                                    },
                                    "actual_duration": {
                                        "description": "Durasi aktual yang diselesaikan dalam menit",
                                        "type": "integer",
                                        "example": 25
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Sesi fokus selesai atau dibatalkan"
                    },
                    "404": {
                        "description": "Sesi tidak ditemukan atau tidak sedang berjalan"
                    }
                },
                "security": [
                    {
                        "bearerAuth": []
                    }
                ]
            }
        },
        "/api/focus-session/ongoing": {
            "get": {
                "tags": [
                    "Focus Session"
                ],
                "summary": "Cek sesi yang sedang berjalan",
                "description": "Mendapatkan data sesi fokus milik user yang saat ini masih berstatus 'ongoing'.",
                "operationId": "9e6c7c6c94c41636d1aff03b3abd43ac",
                "responses": {
                    "200": {
                        "description": "Berhasil mengambil data sesi (bisa mengembalikan null jika tidak ada)"
                    }
                },
                "security": [
                    {
                        "bearerAuth": []
                    }
                ]
            }
        },
        "/api/focus-session/history": {
            "get": {
                "tags": [
                    "Focus Session"
                ],
                "summary": "Riwayat sesi fokus",
                "description": "Menampilkan riwayat semua sesi fokus (completed/cancelled) dengan fitur pagination dan filter tanggal.",
                "operationId": "20e7ef393efd42d4e88956af9ab4c3b8",
                "parameters": [
                    {
                        "name": "per_page",
                        "in": "query",
                        "description": "Jumlah data per halaman",
                        "required": false,
                        "schema": {
                            "type": "integer",
                            "example": 15
                        }
                    },
                    {
                        "name": "date",
                        "in": "query",
                        "description": "Filter tanggal (Format YYYY-MM-DD)",
                        "required": false,
                        "schema": {
                            "type": "string",
                            "example": "2026-06-22"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Berhasil mengambil riwayat sesi"
                    }
                },
                "security": [
                    {
                        "bearerAuth": []
                    }
                ]
            }
        },
        "/api/focus-session/stats": {
            "get": {
                "tags": [
                    "Focus Session"
                ],
                "summary": "Statistik total jam fokus",
                "description": "Mengambil rangkuman statistik waktu fokus user (total menit, hari ini, minggu ini, bulan ini) serta statistik harian untuk grafik.",
                "operationId": "47f4bc56a3490461d42068fcbfd1b8b3",
                "responses": {
                    "200": {
                        "description": "Berhasil mengambil statistik fokus"
                    }
                },
                "security": [
                    {
                        "bearerAuth": []
                    }
                ]
            }
        },
