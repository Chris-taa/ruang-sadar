{
    "openapi": "3.0.0",
    "info": {
        "title": "RuangSadar API",
        "description": "Dokumentasi API untuk RuangSadar",
        "version": "1.0.0"
    },
    "servers": [
        {
            "url": "https://ruang-sadar-production.up.railway.app/",
            "description": "Production Server (Railway)"
        },
        {
            "url": "http://127.0.0.1:8000",
            "description": "Local Server"
        }
    ],
    "paths": {
        "/api/register": {
            "post": {
                "tags": [
                    "Auth"
                ],
                "summary": "Register akun baru",
                "operationId": "a718f172ff3ac464d723835815f8fb57",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "name",
                                    "email",
                                    "username",
                                    "password",
                                    "role"
                                ],
                                "properties": {
                                    "name": {
                                        "type": "string",
                                        "example": "Christian Candra"
                                    },
                                    "email": {
                                        "type": "string",
                                        "format": "email",
                                        "example": "chris@example.com"
                                    },
                                    "username": {
                                        "type": "string",
                                        "example": "chris123"
                                    },
                                    "password": {
                                        "type": "string",
                                        "format": "password",
                                        "example": "password123"
                                    },
                                    "role": {
                                        "description": "Pilihan: patient atau therapist",
                                        "type": "string",
                                        "example": "patient"
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "201": {
                        "description": "Registrasi berhasil"
                    },
                    "422": {
                        "description": "Data tidak valid"
                    }
                }
            }
        },
        "/api/login": {
            "post": {
                "tags": [
                    "Auth"
                ],
                "summary": "Login user",
                "operationId": "44212a9096e4b09358281e9ec8a0701d",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "email",
                                    "password"
                                ],
                                "properties": {
                                    "email": {
                                        "type": "string",
                                        "format": "email",
                                        "example": "chris@example.com"
                                    },
                                    "password": {
                                        "type": "string",
                                        "format": "password",
                                        "example": "password123"
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Login berhasil"
                    },
                    "401": {
                        "description": "Email atau password salah"
                    }
                }
            }
        },
        "/api/auth/google": {
            "post": {
                "tags": [
                    "Auth"
                ],
                "summary": "Login dengan akun Google",
                "description": "Menerima id_token dari Android, memvalidasinya, dan mengembalikan token akses",
                "operationId": "f53e9b3810807365b968103a33b5c93f",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "id_token"
                                ],
                                "properties": {
                                    "id_token": {
                                        "description": "ID Token dari Google Sign-In Android",
                                        "type": "string"
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Berhasil login/register via Google"
                    },
                    "401": {
                        "description": "Token Google tidak valid"
                    }
                }
            }
        },
        "/api/journal": {
            "get": {
                "tags": [
                    "Journal"
                ],
                "summary": "Ambil riwayat jurnal pengguna",
                "description": "Menampilkan daftar jurnal khusus milik user yang sedang login. Bisa difilter berdasarkan tanggal.",
                "operationId": "bead93448320c17eec49e73f8911af31",
                "parameters": [
                    {
                        "name": "date",
                        "in": "query",
                        "description": "Filter berdasarkan tanggal (Format: YYYY-MM-DD)",
                        "required": false,
                        "schema": {
                            "type": "string",
                            "example": "2026-06-22"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Berhasil mengambil data jurnal"
                    },
                    "401": {
                        "description": "Unauthenticated"
                    }
                },
                "security": [
                    {
                        "bearerAuth": []
                    }
                ]
            },
            "post": {
                "tags": [
                    "Journal"
                ],
                "summary": "Simpan jurnal baru",
                "description": "Menambahkan catatan jurnal baru dengan detail mood dan penyebabnya",
                "operationId": "9c8043e3a2a19ad4ff66313e22edea62",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "mood",
                                    "date"
                                ],
                                "properties": {
                                    "mood": {
                                        "type": "string",
                                        "example": "Senang"
                                    },
                                    "cause": {
                                        "type": "array",
                                        "items": {
                                            "type": "string"
                                        },
                                        "example": [
                                            "Tugas Selesai",
                                            "Tidur Cukup"
                                        ]
                                    },
                                    "contain": {
                                        "type": "string",
                                        "example": "Hari ini sangat produktif dan menyenangkan."
                                    },
                                    "date": {
                                        "type": "string",
                                        "format": "date-time",
                                        "example": "2026-06-22 18:30:00"
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "201": {
                        "description": "Jurnal berhasil disimpan"
                    },
                    "401": {
                        "description": "Unauthenticated"
                    },
                    "422": {
                        "description": "Data tidak valid"
                    }
                },
                "security": [
                    {
                        "bearerAuth": []
                    }
                ]
            }
        },
        "/api/journal/{id}": {
            "get": {
                "tags": [
                    "Journal"
                ],
                "summary": "Detail satu jurnal",
                "description": "Menampilkan detail satu jurnal berdasarkan ID",
                "operationId": "400b43ba67c4abf6205db31127a4a396",
                "parameters": [
                    {
                        "name": "id",
                        "in": "path",
                        "description": "ID Jurnal",
                        "required": true,
                        "schema": {
                            "type": "integer"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Berhasil mengambil detail jurnal"
                    },
                    "404": {
                        "description": "Jurnal tidak ditemukan"
                    }
                },
                "security": [
                    {
                        "bearerAuth": []
                    }
                ]
            },
            "put": {
                "tags": [
                    "Journal"
                ],
                "summary": "Update jurnal",
                "description": "Memperbarui data jurnal yang sudah ada",
                "operationId": "4f827933db95dc34e98ed67c453e5bb7",
                "parameters": [
                    {
                        "name": "id",
                        "in": "path",
                        "description": "ID Jurnal",
                        "required": true,
                        "schema": {
                            "type": "integer"
                        }
                    }
                ],
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "properties": {
                                    "mood": {
                                        "type": "string",
                                        "example": "Biasa Saja"
                                    },
                                    "cause": {
                                        "type": "array",
                                        "items": {
                                            "type": "string"
                                        },
                                        "example": [
                                            "Hujan",
                                            "Bosan"
                                        ]
                                    },
                                    "contain": {
                                        "type": "string",
                                        "example": "Hari ini biasa saja, cuma di rumah."
                                    },
                                    "date": {
                                        "type": "string",
                                        "format": "date-time",
                                        "example": "2026-06-22 19:00:00"
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Jurnal berhasil diperbarui"
                    },
                    "404": {
                        "description": "Jurnal tidak ditemukan"
                    }
                },
                "security": [
                    {
                        "bearerAuth": []
                    }
                ]
            },
            "delete": {
                "tags": [
                    "Journal"
                ],
                "summary": "Hapus jurnal",
                "description": "Menghapus catatan jurnal",
                "operationId": "e961cfd32cfc7ef88c5599d488942c88",
                "parameters": [
                    {
                        "name": "id",
                        "in": "path",
                        "description": "ID Jurnal",
                        "required": true,
                        "schema": {
                            "type": "integer"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Jurnal berhasil dihapus"
                    },
                    "404": {
                        "description": "Jurnal tidak ditemukan"
                    }
                },
                "security": [
                    {
                        "bearerAuth": []
                    }
                ]
            }
        },
        "/api/journal/dates/entries": {
            "get": {
                "tags": [
                    "Journal"
                ],
                "summary": "Ambil tanggal yang ada jurnalnya",
                "description": "Digunakan untuk marker dot di kalender aplikasi (menandai tanggal mana saja yang sudah diisi jurnal)",
                "operationId": "1970cfd084a70e6aa40bee4a42d7f8c4",
                "responses": {
                    "200": {
                        "description": "Berhasil mengambil data tanggal"
                    }
                },
                "security": [
                    {
                        "bearerAuth": []
                    }
                ]
            }
        },
        "/api/patients/appointments": {
            "post": {
                "tags": [
                    "Patient"
                ],
                "summary": "Buat jadwal konsultasi baru",
                "description": "Menyimpan data dari form Atur Jadwal",
                "operationId": "4a053cfa62a42a38721cf5dd97e4c68b",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "therapist_id",
                                    "full_name",
                                    "consultation_date",
                                    "topic",
                                    "method"
                                ],
                                "properties": {
                                    "therapist_id": {
                                        "description": "ID Psikolog/Terapis yang dipilih dari list",
                                        "type": "integer",
                                        "example": 2
                                    },
                                    "full_name": {
                                        "type": "string",
                                        "example": "Budi Santoso"
                                    },
                                    "consultation_date": {
                                        "type": "string",
                                        "format": "date",
                                        "example": "2026-06-25"
                                    },
                                    "topic": {
                                        "type": "string",
                                        "example": "Saya sering merasa cemas akhir-akhir ini karena tugas menumpuk."
                                    },
                                    "method": {
                                        "type": "string",
                                        "example": "online"
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "201": {
                        "description": "Jadwal berhasil dibuat"
                    },
                    "403": {
                        "description": "Akses ditolak (Bukan Pasien)"
                    },
                    "422": {
                        "description": "Data tidak valid"
                    }
                },
                "security": [
                    {
                        "bearerAuth": []
                    }
                ]
            }
        },
        "/api/patients/profile": {
            "put": {
                "tags": [
                    "Patient"
                ],
                "summary": "Ubah profil pasien",
                "description": "Mengupdate data nama dan username khusus untuk pasien yang sedang login",
                "operationId": "ce829cd417104f537f3d6c93fd87dd2f",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "name",
                                    "username"
                                ],
                                "properties": {
                                    "name": {
                                        "type": "string",
                                        "example": "Christian Hadi Candra"
                                    },
                                    "username": {
                                        "type": "string",
                                        "example": "christian_candra"
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Profil berhasil diperbarui"
                    },
                    "403": {
                        "description": "Akses ditolak (Bukan Pasien)"
                    },
                    "422": {
                        "description": "Data tidak valid"
                    }
                },
                "security": [
                    {
                        "bearerAuth": []
                    }
                ]
            }
        },
        "/api/therapists/profile": {
            "put": {
                "tags": [
                    "Therapist"
                ],
                "summary": "Ubah profil terapis",
                "description": "Mengupdate data profil khusus untuk terapis yang sedang login",
                "operationId": "97310cf8cc0b8290585b0685a45d36cf",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "name",
                                    "username"
                                ],
                                "properties": {
                                    "name": {
                                        "type": "string",
                                        "example": "Dr. Dian Sastro, M.Psi"
                                    },
                                    "username": {
                                        "type": "string",
                                        "example": "dian_sastro_psi"
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Profil berhasil diperbarui"
                    },
                    "403": {
                        "description": "Akses ditolak (Bukan Terapis)"
                    },
                    "422": {
                        "description": "Data tidak valid"
                    }
                },
                "security": [
                    {
                        "bearerAuth": []
                    }
                ]
            }
        },
        "/api/therapists/appointments": {
            "get": {
                "tags": [
                    "Therapist"
                ],
                "summary": "Lihat daftar jadwal konsultasi",
                "description": "Mengambil semua jadwal pasien yang masuk ke terapis ini",
                "operationId": "f3fd07b2f32bec6224d2c99ef3d1c2d1",
                "responses": {
                    "200": {
                        "description": "Berhasil mengambil jadwal"
                    },
                    "403": {
                        "description": "Akses ditolak"
                    }
                },
                "security": [
                    {
                        "bearerAuth": []
                    }
                ]
            }
        },
        "/api/therapists/appointments/{id}/status": {
            "patch": {
                "tags": [
                    "Therapist"
                ],
                "summary": "Ubah status jadwal konsultasi",
                "description": "Mengubah status jadwal menjadi approved, completed, atau cancelled",
                "operationId": "e4be8c7408fc222aa3b104183620a652",
                "parameters": [
                    {
                        "name": "id",
                        "in": "path",
                        "description": "ID Jadwal (Appointment)",
                        "required": true,
                        "schema": {
                            "type": "integer"
                        }
                    }
                ],
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "status"
                                ],
                                "properties": {
                                    "status": {
                                        "description": "Pilihan: approved, completed, cancelled",
                                        "type": "string",
                                        "example": "approved"
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Status berhasil diubah"
                    },
                    "404": {
                        "description": "Jadwal tidak ditemukan"
                    }
                },
                "security": [
                    {
                        "bearerAuth": []
                    }
                ]
            }
        },
        "/api/videos": {
            "get": {
                "tags": [
                    "Video"
                ],
                "summary": "Ambil semua daftar video",
                "description": "Mendapatkan list video, bisa difilter berdasarkan kategori melalui query parameter",
                "operationId": "146978877bfb1a6b73cf56db141eaa3a",
                "parameters": [
                    {
                        "name": "category",
                        "in": "query",
                        "description": "Filter video berdasarkan kategori (opsional)",
                        "required": false,
                        "schema": {
                            "type": "string",
                            "example": "Anxiety"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Berhasil mengambil data video"
                    },
                    "401": {
                        "description": "Unauthenticated"
                    }
                },
                "security": [
                    {
                        "bearerAuth": []
                    }
                ]
            }
        },
        "/api/videos/{id}": {
            "get": {
                "tags": [
                    "Video"
                ],
                "summary": "Ambil detail video berdasarkan ID",
                "description": "Mendapatkan data spesifik dari satu video",
                "operationId": "d605cccdd1603726ce4c710a466cbf0d",
                "parameters": [
                    {
                        "name": "id",
                        "in": "path",
                        "description": "ID Video",
                        "required": true,
                        "schema": {
                            "type": "integer",
                            "example": 1
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Berhasil menemukan video"
                    },
                    "404": {
                        "description": "Video tidak ditemukan"
                    },
                    "401": {
                        "description": "Unauthenticated"
                    }
                },
                "security": [
                    {
                        "bearerAuth": []
                    }
                ]
            }
        }
    },
    "components": {
        "securitySchemes": {
            "bearerAuth": {
                "type": "http",
                "scheme": "bearer"
            }
        }
    },
    "tags": [
        {
            "name": "Auth",
            "description": "API Otentikasi User"
        },
        {
            "name": "Journal",
            "description": "API untuk mengelola jurnal mindfulness"
        },
        {
            "name": "Patient",
            "description": "API untuk fitur dan data khusus pasien"
        },
        {
            "name": "Therapist",
            "description": "API untuk fitur dan data khusus terapis"
        },
        {
            "name": "Video",
            "description": "API untuk mengelola video"
        }
    ]
}